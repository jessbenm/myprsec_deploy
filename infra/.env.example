# ╔══════════════════════════════════════════════════════════════════════════╗
# ║               MyPresc Deploy — Environment Variables                    ║
# ║  Copy this file to .env at the repo root, then fill in all values.     ║
# ║  NEVER commit the .env file to git.                                     ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── DOMAIN & URLs ────────────────────────────────────────────────────────────

# Your public domain name (no https://, no trailing slash)
# Example: mypresc.example.com
DOMAIN=

# Full URL the frontend uses to reach the API (used in Vite build if needed)
# Example: https://mypresc.example.com
VITE_API_URL=

# Full WebSocket URL for the terminal feature
# Example: wss://mypresc.example.com
VITE_WS_URL=

# HTTP/HTTPS ports on the host (use free ports if another app already owns 80/443)
HTTP_PORT=80
HTTPS_PORT=443

# ── BACKEND ──────────────────────────────────────────────────────────────────

# Internal port the backend Express server listens on (container port)
BACKEND_PORT=3001

# Redis connection string used for auth sessions
REDIS_URL=redis://redis:6379

# Node environment
NODE_ENV=production

# AES-256-GCM key for encrypting SSH passwords and OAuth tokens in SQLite.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters. KEEP THIS SECRET.
ENCRYPTION_KEY=

# ── GITHUB OAUTH ─────────────────────────────────────────────────────────────

# Create your OAuth App at: https://github.com/settings/developers
# → New OAuth App
# → Homepage URL:              https://<DOMAIN>
# → Authorization callback URL: https://<DOMAIN>/api/auth/github/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Must match your DOMAIN (used by the backend for OAuth redirects)
FRONTEND_URL=https://${DOMAIN}

# ── CERTBOT / SSL ─────────────────────────────────────────────────────────────

# Email address for Let's Encrypt notifications (certificate expiry warnings)
CERTBOT_EMAIL=

# Domain for which the certificate is issued — same as DOMAIN above
# The current init-ssl script uses DNS-01 validation, so it does not require port 80.
CERTBOT_DOMAIN=${DOMAIN}

# ── NGINX ────────────────────────────────────────────────────────────────────

# Which nginx config to use:
#   nossl — HTTP only (use during first deploy before SSL cert is obtained)
#   ssl   — HTTPS with Let's Encrypt (use after running init-ssl.sh)
NGINX_CONFIG=nossl

# ── DOCKER REGISTRY (CI/CD only) ─────────────────────────────────────────────

# Registry prefix for built images (used by GitHub Actions)
# Example: ghcr.io/your-github-username
# Leave empty for local builds only
REGISTRY=

# Image tag (set by CI to git SHA, defaults to "latest" locally)
IMAGE_TAG=latest

# ── BACKUP ───────────────────────────────────────────────────────────────────

# How many daily backup files to keep (older ones are deleted)
BACKUP_RETENTION_DAYS=7

# Directory on the HOST where backups are stored
# Example: /opt/mypresc/backups
BACKUP_DIR=/opt/mypresc/backups

# ── DEV ONLY ─────────────────────────────────────────────────────────────────

# Vite dev server port (docker-compose.override.yml)
VITE_PORT=5173
