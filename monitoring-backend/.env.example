# ─────────────────────────────────────────────────────────────────────────────
# MyPresc Deploy — Backend Environment Variables Template
# Copy this file to .env and fill in all values before starting the server.
# ─────────────────────────────────────────────────────────────────────────────

# Required — AES-256 encryption key for SSH passwords and API tokens stored in DB.
# Must be exactly 64 hex characters (32 bytes).
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
ENCRYPTION_KEY=your_64_hex_char_encryption_key_here

# Optional
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
DATABASE_PATH=./metrics-history.db
COOKIE_SAMESITE=Lax
COOKIE_SECURE=false
