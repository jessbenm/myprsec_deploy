# ── RAG DevOps Assistant — Environment Variables ────────────────────────────
# Copy to rag/.env for local development only.
# In production, all variables are injected by docker-compose.
# NEVER commit rag/.env to git.

# Port the RAG server listens on
RAG_PORT=3002

# Groq API key — get yours at https://console.groq.com/
GROQ_API_KEY=

# Groq model to use
GROQ_MODEL=llama-3.3-70b-versatile

# Backend URL (local dev: localhost, Docker: http://backend:3001)
BACKEND_URL=http://backend:3001

# JWT secret — must match the backend's JWT_SECRET
JWT_SECRET=

# Path to the knowledge-base markdown files
KNOWLEDGE_BASE_PATH=./knowledge-base

# Path where the vector index is stored/loaded
INDEX_PATH=./index/knowledge-index.json

# Number of knowledge chunks returned per question
RAG_TOP_K=5
